# AgentDesk server defaults
PORT=8790
HOST=127.0.0.1

# Required: encrypt OAuth + messenger channel tokens stored in SQLite.
# Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
OAUTH_ENCRYPTION_SECRET="e6c289cbff55b1fda343723081d01b6fd6cc7d7a3db238f88220869aebda20a7"

# Optional legacy fallback for OAUTH_ENCRYPTION_SECRET
# SESSION_SECRET="__CHANGE_ME__"

# Optional runtime paths (defaults: ./agentdesk.sqlite and ./logs)
# DB_PATH="./agentdesk.sqlite"
# LOGS_DIR="./logs"

# Optional callback base URL override
# OAUTH_BASE_URL="http://127.0.0.1:8790"

# Optional API auth token (required for non-loopback access)
# API_AUTH_TOKEN="__CHANGE_ME__"

# Remote browser clients provide API_AUTH_TOKEN at runtime.
# It is not embedded in frontend build artifacts.

# Optional extra trusted origins/suffixes for CORS
# ALLOWED_ORIGINS="https://claw.example.com"
# ALLOWED_ORIGIN_SUFFIXES=".ts.net,.example.com"

# GitHub OAuth (Settings -> Developer settings -> OAuth Apps)
# OAUTH_GITHUB_CLIENT_ID="__CHANGE_ME__"
# OAUTH_GITHUB_CLIENT_SECRET="__CHANGE_ME__"

# Google OAuth (Google Cloud Console -> OAuth consent screen)
# OAUTH_GOOGLE_CLIENT_ID="__CHANGE_ME__"
# OAUTH_GOOGLE_CLIENT_SECRET="__CHANGE_ME__"

# Optional explicit Gemini OAuth credentials
# GEMINI_OAUTH_CLIENT_ID="__CHANGE_ME__"
# GEMINI_OAUTH_CLIENT_SECRET="__CHANGE_ME__"

# Optional model provider settings
# OPENAI_API_KEY="__CHANGE_ME__"
# GOOGLE_CLOUD_PROJECT="__CHANGE_ME__"
# GOOGLE_CLOUD_PROJECT_ID="__CHANGE_ME__"

# Messenger channel tokens/sessions are now managed in UI Settings.

# Required for /api/inbox webhook endpoint (sent via x-inbox-secret header)
INBOX_WEBHOOK_SECRET="cf036159115e9f65184557624b108f91a72c47e7f13fb9bd38ff47096d9eff42"

# Optional meeting prompt budget tuning
MEETING_PROMPT_TASK_CONTEXT_MAX_CHARS=1200
MEETING_TRANSCRIPT_MAX_TURNS=20
MEETING_TRANSCRIPT_LINE_MAX_CHARS=180
MEETING_TRANSCRIPT_TOTAL_MAX_CHARS=2400
REVIEW_MEETING_ONESHOT_TIMEOUT_MS=65000
# Milliseconds. (Backward compatibility: values <= 600 are treated as seconds.)

# Internal one-time migration marker (auto-managed by v1.0.5 runtime migration)
AGENTDESK_MIGRATION_V1_DONE=1
